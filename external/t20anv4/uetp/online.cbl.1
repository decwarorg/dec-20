	02  F PIC X(25) VALUE
		'ALREADY CUSTOMER'.
	02  F PIC X(25) VALUE
		'NO BRANCH PO'.
	02  F PIC X(25) VALUE
		'METER CUST LINKED'.
	02  F PIC X(25) VALUE
		'METER BRANCH LINKED'.
	02  F PIC X(25) VALUE
		'NO PARENT PO'.
	02  F PIC X(25) VALUE
		'BRANCH PARENT LINKED'.
	02  F PIC X(25) VALUE
		'METER CUST NOT LINKED'.
	02  F PIC X(25) VALUE
		'ALREADY PARENT PO'.
	02  F PIC X(25) VALUE
		'ALREADY BRANCH PO'.
	02  F PIC X(25) VALUE
		'DATABASE ERROR'.
